The server entry point configures Express middleware, database connection, routes, and starts the server:\
\pard\pardeftab720\pardirnatural\partightenfactor0

\f10\fs18 \cf0 import express from 'express';\uc0\u8232 import cors from 'cors';\u8232 import cookieParser from 'cookie-parser';\u8232 import rateLimit from 'express-rate-limit';\u8232 import connectMongoDb from './connectMongoDb.js';\u8232 import authRoutes from './routes/auth.js';\u8232 import questionRoutes from './routes/Questions.js';\u8232 \u8232 const app = express();\u8232 const limiter = rateLimit(\{ windowMs: 15*60*1000, max: 100 \});\u8232 \u8232 app.use(cors(\{ origin: process.env.CLIENT_URL, credentials: true \}));\u8232 app.use(express.json(\{ limit: '10mb' \}));\u8232 app.use(cookieParser());\u8232 app.use(limiter);\u8232 \u8232 app.use('/api/auth', authRoutes);\u8232 app.use('/api/questions', questionRoutes);\u8232 \u8232 connectMongoDb();\u8232 app.listen(5000, () => console.log('Server running on port 5000'));\
\pard\pardeftab720\pardirnatural\partightenfactor0

\f1\fs24 \cf0 5.2.2 Reputation Utility (server/utils/reputation.js)\
The reputation utility function handles all reputation and badge updates:\
\pard\pardeftab720\pardirnatural\partightenfactor0

\f10\fs18 \cf0 import User from '../models/auth.js';\uc0\u8232 \u8232 export const updateReputation = async (userId, delta) => \{\u8232   const user = await User.findById(userId);\u8232   if (!user) return;\u8232 \u8232   user.reputation = (user.reputation || 0) + delta;\u8232 \u8232   // Badge thresholds\u8232   const badges = [\u8232     \{ name: 'Informed',   threshold: 1   \},\u8232     \{ name: 'Enthusiast', threshold: 10  \},\u8232     \{ name: 'Veteran',    threshold: 50  \},\u8232     \{ name: 'Expert',     threshold: 200 \},\u8232   ];\u8232 \u8232   for (const badge of badges) \{\u8232     if (user.reputation >= badge.threshold &&\u8232         !user.badges.includes(badge.name)) \{\u8232       user.badges.push(badge.name);\u8232     \}\u8232   \}\u8232 \u8232   await user.save();\u8232 \};\
\pard\pardeftab720\pardirnatural\partightenfactor0

\f1\fs24 \cf0 5.2.3 Question Controller (server/controllers/Questions.js)\
The Questions controller handles creation, retrieval, voting, and deletion:\
\pard\pardeftab720\pardirnatural\partightenfactor0

\f10\fs18 \cf0 export const createQuestion = async (req, res) => \{\uc0\u8232   try \{\u8232     const \{ title, body, tags \} = req.body;\u8232     if (!title || !body || !tags?.length) \{\u8232       return res.status(400).json(\{ message: 'All fields required' \});\u8232     \}\u8232     const question = new Question(\{\u8232       title, body, tags,\u8232       author: req.userId,\u8232     \});\u8232     await question.save();\u8232     res.status(201).json(question);\u8232   \} catch (err) \{\u8232     res.status(500).json(\{ message: err.message \});\u8232   \}\u8232 \};\u8232 \u8232 export const voteQuestion = async (req, res) => \{\u8232   const \{ id \} = req.params;\u8232   const \{ vote \} = req.body;  // +1 or -1\u8232   const question = await Question.findByIdAndUpdate(\u8232     id, \{ $inc: \{ votes: vote \} \}, \{ new: true \}\u8232   );\u8232   await updateReputation(question.author, vote * 5); // +5 or -5\u8232   res.json(question);\u8232 \};\
\pard\pardeftab720\pardirnatural\partightenfactor0

\f1\fs24 \cf0 5.2.4 Auth Middleware (server/middleware/auth.js)\
JWT authentication middleware that protects all private routes:\
\pard\pardeftab720\pardirnatural\partightenfactor0

\f10\fs18 \cf0 import jwt from 'jsonwebtoken';\uc0\u8232 \u8232 const authMiddleware = (req, res, next) => \{\u8232   const token = req.cookies?.accessToken;\u8232   if (!token) \{\u8232     return res.status(401).json(\{ message: 'Not authenticated' \});\u8232   \}\u8232   try \{\u8232     const decoded = jwt.verify(token, process.env.JWT_SECRET);\u8232     req.userId = decoded.id;\u8232     next();\u8232   \} catch (err) \{\u8232     return res.status(401).json(\{ message: 'Invalid or expired token' \});\u8232   \}\u8232 \};\u8232 \u8232 export default authMiddleware;\
\pard\pardeftab720\pardirnatural\partightenfactor0

