# -----------------------------
# Core server configuration
# -----------------------------
PORT=5000
CONNECTION_URL="mongodb+srv://<username>:<password>@cluster.mongodb.net/<db-name>?retryWrites=true&w=majority"
JWT_SECRET="replace-with-a-strong-random-secret"

# -----------------------------
# SMTP configuration (for OTP emails)
# -----------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@example.com"
SMTP_PASS="your-app-password-or-smtp-password"
SMTP_SECURE=false
SMTP_FROM="BugOverflow <no-reply@bugoverflow.com>"

# -----------------------------
# OTP Notes
# -----------------------------
# 1) Signup and forgot-password now use 6-digit OTP sent over email.
# 2) OTP expiry is currently 10 minutes (configured in server/controllers/auth.js).
# 3) If SMTP variables are missing, OTP is logged in server console for local development fallback.
# 4) For Gmail SMTP, use an App Password (2FA enabled) instead of your account password.